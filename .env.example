# Rakit Environment Configuration
# Copy this file to .env and fill in the values before running locally.

# [REQUIRED] GitHub Personal Access Token (PAT) with generic `repo` access.
# This enables the compilation engine to commit generated HTML files directly to your repo.
GITHUB_TOKEN="ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# [REQUIRED] The target repository where compiled websites will be stored.
# Format: username/repository-name (e.g., hasanh47/rakit-sites)
GITHUB_REPO="hasanh47/rakit-sites"
